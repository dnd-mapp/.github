{
  "name": "@dnd-mapp/dot-github",
  "version": "0.0.0",
  "description": "TypeScript-based automation, CI/CD logic, and shared configurations for the dnd-mapp organization.",
  "author": "NoNamer777",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "node build.mts",
    "test": "vitest run",
    "test:development": "vitest --ui --watch",
    "lint": "pnpm lint:eslint && pnpm lint:markdownlint",
    "lint:eslint": "eslint \"**/*\" --cache",
    "lint:markdownlint": "markdownlint \"**/*.md\"",
    "format:check": "prettier -l .",
    "format:write": "prettier -w ."
  },
  "engines": {
    "node": "~24.15"
  },
  "packageManager": "pnpm@11.0.8",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "~24.15",
      "onFail": "error"
    },
    "packageManager": [
      {
        "name": "pnpm",
        "version": "11.0.8",
        "onFail": "error"
      }
    ]
  },
  "dependencies": {
    "@actions/core": "~3.0.1",
    "@actions/github": "~9.1.1",
    "semver": "~7.7.4"
  },
  "devDependencies": {
    "@eslint/js": "~10.0.1",
    "@types/node": "~24.12.2",
    "@types/semver": "~7.7.1",
    "@vitest/coverage-v8": "~4.1.5",
    "@vitest/ui": "~4.1.5",
    "esbuild": "~0.28.0",
    "eslint": "~10.3.0",
    "eslint-config-prettier": "~10.1.8",
    "globals": "~17.6.0",
    "markdownlint": "~0.40.0",
    "markdownlint-cli": "~0.48.0",
    "prettier": "~3.8.3",
    "prettier-plugin-organize-imports": "~4.3.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "~8.59.2",
    "vite": "~8.0.11",
    "vitest": "~4.1.5"
  }
}
